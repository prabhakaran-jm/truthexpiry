{
  "display_information": {
    "name": "TruthExpiry",
    "description": "Prevents Slack agents from repeating stale information using public-channel evidence and deterministic claim validation.",
    "background_color": "#2c2d30"
  },
  "features": {
    "assistant_view": {
      "assistant_description": "TruthExpiry checks whether Slack answers are still current using public workspace evidence and authoritative lifecycle records.",
      "suggested_prompts": []
    },
    "app_home": {
      "home_tab_enabled": true,
      "messages_tab_enabled": true,
      "messages_tab_read_only_enabled": false
    },
    "bot_user": {
      "display_name": "TruthExpiry",
      "always_online": true
    }
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "app_mentions:read",
        "assistant:write",
        "channels:history",
        "chat:write",
        "im:history",
        "im:read",
        "im:write",
        "reactions:read",
        "reactions:write",
        "search:read.public",
        "users:read"
      ]
    }
  },
  "settings": {
    "event_subscriptions": {
      "bot_events": [
        "app_home_opened",
        "app_mention",
        "assistant_thread_started",
        "message.im"
      ]
    },
    "interactivity": {
      "is_enabled": true
    },
    "is_mcp_enabled": false,
    "org_deploy_enabled": true,
    "socket_mode_enabled": true,
    "token_rotation_enabled": false
  }
}
