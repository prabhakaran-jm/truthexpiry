# Required, set at least one AI provider API key.
# If both are set, Anthropic is used by default.
# ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY
OPENAI_API_KEY=placeholder

# Required for python app.py (Socket Mode Slack app).
SLACK_BOT_TOKEN=xoxb-placeholder
SLACK_APP_TOKEN=xapp-placeholder

# Optional, uncomment and set when using a custom Slack instance.
# SLACK_API_URL=YOUR_SLACK_API_URL

# --- TruthExpiry composition ---

# All-fake mode (default for local dev and unit tests).
# RTS, lifecycle evidence, and claim extraction use in-process fakes.
TRUTH_EXPIRY_USE_FAKES=1

# Milestone 2 real mode: unset TRUTH_EXPIRY_USE_FAKES and provide both values below.
# Requires an eligible internal development app with search:read.public installed.
# TRUTH_EXPIRY_LIFECYCLE_MCP_URL=http://127.0.0.1:8000/mcp
# TRUTH_EXPIRY_LIFECYCLE_MCP_AUTH_TOKEN=placeholder

# Local lifecycle MCP development only — disable bearer auth requirement.
# TRUTH_EXPIRY_LIFECYCLE_MCP_AUTH_DISABLED=1

# Milestone 3 claim extractor (when TRUTH_EXPIRY_USE_FAKES is unset).
# fake = FakeClaimExtractionPort (default when unset)
# live = OpenAI-backed extraction (requires non-blank OPENAI_API_KEY)
# TRUTH_EXPIRY_CLAIM_EXTRACTOR=live

# Lifecycle MCP server bind settings (server process only — not read by the Slack app).
# TRUTH_EXPIRY_LIFECYCLE_MCP_HOST=127.0.0.1
# TRUTH_EXPIRY_LIFECYCLE_MCP_PORT=8000
# TRUTH_EXPIRY_LIFECYCLE_MCP_HEALTH_PORT=8001
# TRUTH_EXPIRY_MCP_SHUTDOWN_SECONDS=10
# TRUTH_EXPIRY_LIFECYCLE_MCP_DATASET_PATH=

# Slack worker operational settings (parsed in M4; behavior wired in later commits).
# TRUTH_EXPIRY_LOG_LEVEL=INFO
# TRUTH_EXPIRY_LOG_FORMAT=text
# TRUTH_EXPIRY_HEALTH_HOST=0.0.0.0
# TRUTH_EXPIRY_HEALTH_PORT=8080
# TRUTH_EXPIRY_SLACK_TIMEOUT_SECONDS=30
# TRUTH_EXPIRY_MCP_CLIENT_TIMEOUT_SECONDS=10
# TRUTH_EXPIRY_MCP_READINESS_TIMEOUT_SECONDS=60
# TRUTH_EXPIRY_SHUTDOWN_DRAIN_SECONDS=30
# TRUTH_EXPIRY_METRICS_ENABLED=0
# TRUTH_EXPIRY_METRICS_PORT=9090
# TRUTH_EXPIRY_DEDUP_EVENT_IDS=0
# TRUTH_EXPIRY_LIFECYCLE_MCP_HEALTH_URL=http://127.0.0.1:8001
